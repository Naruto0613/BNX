rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Profiles
    match /profiles/{userId} {
      allow read, write: if isSignedIn() && userId == request.auth.uid;
    }

    // Tracks / Applications
    match /tracks/{trackId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid) && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }

    // Essays
    match /essays/{essayId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid) && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }

    // Custom Universities
    match /custom_universities/{universityId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Custom Scholarships
    match /custom_scholarships/{scholarshipId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
